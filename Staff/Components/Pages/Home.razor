@page "/"
@attribute [Authorize]

@inject EmployeeFacade EmployeeFacade
@inject OrganizationFacade OrganizationFacade

<PageTitle>Главная</PageTitle>

<h1>Справочник сотрудников в системе</h1>

@if (organizations is null)
{
    <p><em>Загрузка...</em></p>
}
else if (organizations.Count == 0)
{
    <div class="alert alert-info">Организации пока не добавлены.</div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">Организации</div>
                <div class="list-group list-group-flush">
                    @foreach (var organization in organizations)
                    {
                        var isSelected = organization.Id == selectedOrganization?.Id;
                        <a class="list-group-item list-group-item-action @(isSelected ? "active" : null)"
                           href="@GetOrganizationUrl(organization.Id)">
                            <div>
                                <div>@organization.Name</div>
                                <small class="@(isSelected ? "text-white-50" : "text-muted")">ИНН: @organization.Inn</small>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            @if (selectedOrganization is null)
            {
                <div class="alert alert-warning">Выберите организацию для просмотра сотрудников.</div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-wrap">
                    <div>
                        <h2 class="h4 mb-1">@selectedOrganization.Name</h2>
                        <div class="text-muted">Сотрудники организации</div>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        @if (canOpenOrganizations)
                        {
                            <a class="btn btn-outline-secondary" href="@($"/organizations/{selectedOrganization.Id}")">Карточка организации</a>
                        }
                        @if (canManageEmployees)
                        {
                            <a class="btn btn-primary" href="@($"/organizations/{selectedOrganization.Id}/employees/new")">Добавить сотрудника</a>
                        }
                    </div>
                </div>

                @if (employees.Count == 0)
                {
                    <div class="alert alert-info">В этой организации пока нет сотрудников.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>ФИО</th>
                                    <th>Должность</th>
                                    <th>Пользователь</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var employee in employees)
                                {
                                    <tr>
                                        <td>
                                            <a href="@($"/employees/{employee.Id}")">@GetFullName(employee)</a>
                                        </td>
                                        <td>@(employee.Position?.Name ?? "—")</td>
                                        <td>@GetUserDisplay(employee)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "organizationId")]
    public int? OrganizationId { get; set; }

    private List<Organization>? organizations;
    private List<Employee> employees = [];
    private Organization? selectedOrganization;
    private bool canManageEmployees;
    private bool canOpenOrganizations;

    protected override async Task OnParametersSetAsync()
    {
        organizations = await OrganizationFacade.GetAllAsync();
        // Если id пришёл из query, открываем эту организацию, иначе просто первую.
        selectedOrganization = organizations
            .FirstOrDefault(x => x.Id == OrganizationId)
            ?? organizations.FirstOrDefault();

        if (selectedOrganization is not null)
        {
            employees = await EmployeeFacade.GetByOrganizationIdAsync(selectedOrganization.Id);
        }
        else
        {
            employees = [];
        }

        var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        // Права считаем один раз тут, чтобы потом просто управлять кнопками в разметке.
        canManageEmployees = user.IsInRole(AppRoles.Admin) || user.IsInRole(AppRoles.Hr);
        canOpenOrganizations = user.IsInRole(AppRoles.Admin) || user.IsInRole(AppRoles.Hr) || user.IsInRole(AppRoles.Lawyer);
    }

    [Inject]
    private AuthenticationStateProvider AuthenticationStateProvider { get; set; } = null!;

    private static string GetFullName(Employee employee) =>
        $"{employee.LastName} {employee.FirstName} {employee.MiddleName}";

    private static string GetUserDisplay(Employee employee)
    {
        var email = employee.User.Email;
        // Служебные local-логины в таблице смысла показывать нет.
        if (string.IsNullOrWhiteSpace(email) || email.EndsWith("@local", StringComparison.OrdinalIgnoreCase))
        {
            return "—";
        }

        return email;
    }

    private string GetOrganizationUrl(int organizationId) => $"/?organizationId={organizationId}";
}
