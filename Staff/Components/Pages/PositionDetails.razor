@page "/positions/{Id:int}"
@attribute [Authorize(Roles = AppRoles.ManagementAccess)]
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject PositionFacade PositionFacade

<PageTitle>Карточка должности</PageTitle>

@if (position is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <h1>@position.Name</h1>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Название</dt>
                <dd class="col-sm-9">@position.Name</dd>

                <dt class="col-sm-3">Описание</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(position.Description) ? "—" : position.Description)</dd>

                <dt class="col-sm-3">Зарплата</dt>
                <dd class="col-sm-9">@(position.Salary.HasValue ? position.Salary.Value.ToString("N2") : "—")</dd>
            </dl>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-wrap">
        <h2 class="h4 mb-0">Сотрудники на должности</h2>
        @if (canEditPositions)
        {
            <a class="btn btn-outline-secondary" href="@($"/positions/{position.Id}/edit")">Изменить</a>
        }
    </div>

    @if (position.Employees.Count == 0)
    {
        <div class="alert alert-info">На эту должность пока никто не назначен.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>ФИО</th>
                        <th>Организация</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var employee in position.Employees)
                    {
                        <tr>
                            <td><a href="@($"/employees/{employee.Id}")">@employee.LastName @employee.FirstName @employee.MiddleName</a></td>
                            <td>@employee.Organization.Name</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (canEditPositions)
    {
        <div class="mt-4">
            @if (!confirmDelete)
            {
                <button type="button" class="btn btn-outline-danger" @onclick="() => confirmDelete = true">Удалить должность</button>
            }
            else
            {
                <div class="alert alert-warning">
                    <p class="mb-3">Подтвердите удаление должности.</p>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-danger" @onclick="DeleteAsync">Подтвердить удаление</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => confirmDelete = false">Отмена</button>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Position? position;
    private bool canEditPositions;
    private bool confirmDelete;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        canEditPositions = user.IsInRole(AppRoles.Admin) || user.IsInRole(AppRoles.Hr);
        position = await PositionFacade.GetByIdAsync(Id);
    }

    [Inject]
    private AuthenticationStateProvider AuthenticationStateProvider { get; set; } = null!;

    private async Task DeleteAsync()
    {
        try
        {
            await PositionFacade.DeleteAsync(Id);
            NavigationManager.NavigateTo("/positions");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            confirmDelete = false;
        }
    }
}
