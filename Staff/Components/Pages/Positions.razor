@page "/positions"
@attribute [Authorize(Roles = AppRoles.ManagementAccess)]
@rendermode InteractiveServer

@inject PositionFacade PositionFacade

<PageTitle>Должности</PageTitle>

<h1>Должности</h1>

<div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-wrap">
    <p class="mb-0 text-muted">Список должностей системы.</p>
    @if (canEditPositions)
    {
        <a class="btn btn-primary" href="/positions/new">Создать должность</a>
    }
</div>

@if (positions is null)
{
    <p><em>Загрузка...</em></p>
}
else if (positions.Count == 0)
{
    <div class="alert alert-info">Должности пока не добавлены.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Зарплата</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var position in positions)
                {
                    <tr>
                        <td><a href="@($"/positions/{position.Id}")">@position.Name</a></td>
                        <td>@(position.Salary.HasValue ? position.Salary.Value.ToString("N2") : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Position>? positions;
    private bool canEditPositions;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        canEditPositions = user.IsInRole(AppRoles.Admin) || user.IsInRole(AppRoles.Hr);
        positions = await PositionFacade.GetAllAsync();
    }

    [Inject]
    private AuthenticationStateProvider AuthenticationStateProvider { get; set; } = null!;
}
