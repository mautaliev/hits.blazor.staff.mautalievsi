@page "/positions/new"
@page "/positions/{Id:int}/edit"
@attribute [Authorize(Roles = AppRoles.PositionEditors)]
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject PositionFacade PositionFacade

<PageTitle>@pageTitle</PageTitle>

<h1>@pageTitle</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<EditForm Model="model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label" for="name">Название</label>
            <InputText id="name" class="form-control" @bind-Value="model.Name" />
        </div>
        <div class="col-md-6">
            <label class="form-label" for="salary">Зарплата</label>
            <InputNumber id="salary" class="form-control" @bind-Value="model.Salary" />
        </div>
        <div class="col-12">
            <label class="form-label" for="description">Описание</label>
            <InputTextArea id="description" class="form-control" @bind-Value="model.Description" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-outline-secondary" href="@cancelUrl">Отмена</a>
    </div>
</EditForm>

@code {
    [Parameter]
    public int? Id { get; set; }

    private Position model = new();
    private string? errorMessage;
    private string pageTitle = "Создание должности";
    private string cancelUrl = "/positions";

    protected override async Task OnParametersSetAsync()
    {
        if (!Id.HasValue)
        {
            pageTitle = "Создание должности";
            cancelUrl = "/positions";
            model = new Position();
            return;
        }

        var position = await PositionFacade.GetByIdAsync(Id.Value);
        if (position is null)
        {
            NavigationManager.NavigateTo("/positions");
            return;
        }

        pageTitle = "Редактирование должности";
        cancelUrl = $"/positions/{position.Id}";
        model = new Position
        {
            Id = position.Id,
            Name = position.Name,
            Description = position.Description,
            Salary = position.Salary
        };
    }

    private async Task SaveAsync()
    {
        try
        {
            if (Id.HasValue)
            {
                await PositionFacade.SaveAsync(model);
                NavigationManager.NavigateTo($"/positions/{model.Id}");
            }
            else
            {
                var created = await PositionFacade.CreateAsync(model);
                NavigationManager.NavigateTo($"/positions/{created.Id}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}
