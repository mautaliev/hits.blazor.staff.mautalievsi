@page "/organizations"
@attribute [Authorize(Roles = AppRoles.ManagementAccess)]
@rendermode InteractiveServer

@inject OrganizationFacade OrganizationFacade

<PageTitle>Организации</PageTitle>

<h1>Организации</h1>

<div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-wrap">
    <p class="mb-0 text-muted">Список организаций системы.</p>
    @if (canEditOrganizations)
    {
        <a class="btn btn-primary" href="/organizations/new">Создать организацию</a>
    }
</div>

@if (organizations is null)
{
    <p><em>Загрузка...</em></p>
}
else if (organizations.Count == 0)
{
    <div class="alert alert-info">Организаций пока нет.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>ИНН</th>
                    <th>КПП</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var organization in organizations)
                {
                    <tr>
                        <td><a href="@($"/organizations/{organization.Id}")">@organization.Name</a></td>
                        <td>@organization.Inn</td>
                        <td>@(string.IsNullOrWhiteSpace(organization.Kpp) ? "—" : organization.Kpp)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Organization>? organizations;
    private bool canEditOrganizations;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        // Кнопку создания показываем только тем, кому реально можно менять организации.
        canEditOrganizations = user.IsInRole(AppRoles.Admin) || user.IsInRole(AppRoles.Lawyer);
        organizations = await OrganizationFacade.GetAllAsync();
    }

    [Inject]
    private AuthenticationStateProvider AuthenticationStateProvider { get; set; } = null!;
}
