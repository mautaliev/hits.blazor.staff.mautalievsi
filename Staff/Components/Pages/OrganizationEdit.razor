@page "/organizations/new"
@page "/organizations/{Id:int}/edit"
@attribute [Authorize(Roles = AppRoles.OrganizationEditors)]
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject OrganizationFacade OrganizationFacade

<PageTitle>@pageTitle</PageTitle>

<h1>@pageTitle</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<EditForm Model="model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label" for="name">Название</label>
            <InputText id="name" class="form-control" @bind-Value="model.Name" />
        </div>
        <div class="col-md-6">
            <label class="form-label" for="inn">ИНН</label>
            <InputText id="inn" class="form-control" @bind-Value="model.Inn" />
        </div>
        <div class="col-md-6">
            <label class="form-label" for="kpp">КПП</label>
            <InputText id="kpp" class="form-control" @bind-Value="model.Kpp" />
        </div>
        <div class="col-12">
            <label class="form-label" for="description">Описание</label>
            <InputTextArea id="description" class="form-control" @bind-Value="model.Description" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-outline-secondary" href="@cancelUrl">Отмена</a>
    </div>
</EditForm>

@code {
    [Parameter]
    public int? Id { get; set; }

    private Organization model = new();
    private string? errorMessage;
    private string pageTitle = "Создание организации";
    private string cancelUrl = "/organizations";

    protected override async Task OnParametersSetAsync()
    {
        if (!Id.HasValue)
        {
            pageTitle = "Создание организации";
            cancelUrl = "/organizations";
            model = new Organization();
            return;
        }

        var organization = await OrganizationFacade.GetByIdAsync(Id.Value);
        if (organization is null)
        {
            NavigationManager.NavigateTo("/organizations");
            return;
        }

        pageTitle = "Редактирование организации";
        cancelUrl = $"/organizations/{organization.Id}";
        model = new Organization
        {
            Id = organization.Id,
            Name = organization.Name,
            Description = organization.Description,
            Inn = organization.Inn,
            Kpp = organization.Kpp
        };
    }

    private async Task SaveAsync()
    {
        try
        {
            if (Id.HasValue)
            {
                await OrganizationFacade.SaveAsync(model);
                NavigationManager.NavigateTo($"/organizations/{model.Id}");
            }
            else
            {
                var created = await OrganizationFacade.CreateAsync(model);
                NavigationManager.NavigateTo($"/organizations/{created.Id}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}
